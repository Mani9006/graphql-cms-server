{
  "name": "graphql-cms-server",
  "version": "1.0.0",
  "description": "A production-ready GraphQL server for content management with Apollo Server, DataLoader, and real-time subscriptions",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "seed": "node data/seed.js",
    "simulate-commits": "node simulate_commits.js"
  },
  "keywords": [
    "graphql",
    "apollo-server",
    "cms",
    "content-management",
    "dataloader",
    "subscriptions",
    "nodejs"
  ],
  "author": "Mani <myfamily9006@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "apollo-server": "^3.12.0",
    "dataloader": "^2.2.2",
    "graphql": "^16.6.0",
    "graphql-subscriptions": "^2.0.0",
    "subscriptions-transport-ws": "^0.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.44.0",
    "jest": "^29.6.1",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ],
    "testMatch": [
      "**/tests/**/test_*.[jt]s?(x)",
      "**/?(*.)+(test|spec).[jt]s?(x)",
      "**/__tests__/**/*.[jt]s?(x)"
    ]
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
